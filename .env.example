# Copy to `.env` and fill in real values. Do not commit `.env` (see `.gitignore`).

NODE_ENV=
PORT=
BASE_URL=

BACKUP_ENCRYPTION_KEY=
DATABASE_URL=
MONGO_URI=
BACKUP_DIR=

EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
SERVICE=
ADMIN_NOTIFICATION_ROLES=

GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
GOOGLE_DRIVE_FOLDER_ID=
EMAIL_TO=
GOOGLE_DRIVE_CLIENT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=
MONGODUMP_PATH=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

WHATSAPP_API_BASE=
WHATSAPP_ACCESS_TOKEN=

MESSAGING_ENCRYPTION_KEY=

# Optional: short code returned as `data.envMarker` on GET /health so you can confirm `.env` is loaded.
HEALTH_ENV_MARKER=

# --- File storage (local by default; set supabase to use Supabase Storage) ---
# local = save under uploads/ (current behavior)
# supabase = upload to Supabase buckets; old local URLs still served from disk
STORAGE_PROVIDER=local

# Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Service role key (secret) — backend only, never expose in frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Single bucket with images/ and videos/ folders (or separate buckets if you prefer)
SUPABASE_STORAGE_BUCKET=pragalbhjewels
SUPABASE_STORAGE_BUCKET_IMAGES=pragalbhjewels
SUPABASE_STORAGE_BUCKET_VIDEOS=pragalbhjewels
SUPABASE_STORAGE_FOLDER_IMAGES=images
SUPABASE_STORAGE_FOLDER_VIDEOS=videos

# Storage quota shown in Settings > Storage (GB). Default 1 GB. Set 0 for unlimited display.
SUPABASE_STORAGE_QUOTA_GB=1
